{
  "version": 1,
  "author": "PPID LPNU",
  "editor": "wokwi",
  "parts": [
    { "type": "board-esp32-devkit-c-v4", "id": "esp", "top": 0, "left": 0, "attrs": {} },
    {
      "type": "wokwi-led",
      "id": "led1",
      "top": 120,
      "left": 180,
      "attrs": { "color": "green" }
    },
    {
      "type": "wokwi-logic-analyzer",
      "id": "logic1",
      "top": -100,
      "left": 60,
      "attrs": {}
    }
  ],
  "connections": [
    [ "esp:TX", "$serialMonitor:RX", "", [] ],
    [ "esp:RX", "$serialMonitor:TX", "", [] ],
    [ "led1:A", "esp:2", "green", [ "v0" ] ],
    [ "led1:C", "esp:GND.1", "black", [ "v0" ] ],
    [ "logic1:D0", "esp:17", "blue", [ "v0" ] ]
  ],
  "serialMonitor": { "display": "always", "newline": "lf" }
}
