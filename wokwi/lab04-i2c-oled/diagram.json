{
  "version": 1,
  "author": "PPID LPNU",
  "editor": "wokwi",
  "parts": [
    { "type": "board-esp32-devkit-c-v4", "id": "esp", "top": 0, "left": 0, "attrs": {} },
    {
      "type": "wokwi-ssd1306",
      "id": "oled1",
      "top": 96,
      "left": 220,
      "attrs": { "i2cAddress": "0x3c" }
    },
    {
      "type": "wokwi-logic-analyzer",
      "id": "logic1",
      "top": -120,
      "left": 80,
      "attrs": { "channelNames": "SDA,SCL" }
    }
  ],
  "connections": [
    [ "esp:TX", "$serialMonitor:RX", "", [] ],
    [ "esp:RX", "$serialMonitor:TX", "", [] ],
    [ "oled1:VCC", "esp:3V3", "red", [ "v0" ] ],
    [ "oled1:GND", "esp:GND.1", "black", [ "v0" ] ],
    [ "oled1:SDA", "esp:21", "green", [ "v0" ] ],
    [ "oled1:SCL", "esp:22", "yellow", [ "v0" ] ],
    [ "logic1:D0", "esp:21", "green", [ "v0" ] ],
    [ "logic1:D1", "esp:22", "yellow", [ "v0" ] ]
  ],
  "serialMonitor": { "display": "auto", "newline": "lf" }
}
